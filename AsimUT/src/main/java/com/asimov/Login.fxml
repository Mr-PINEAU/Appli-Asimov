<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.asimov.controllers.LoginController"
      alignment="CENTER"
      spacing="20"
      style="-fx-background-color: #f4f4f4;">

    <padding>
        <Insets top="40" right="60" bottom="40" left="60"/>
    </padding>

    <!-- Titre -->
    <Label text="Application Asimov"
           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <Label text="Connexion"
           style="-fx-font-size: 16px; -fx-text-fill: #7f8c8d;"/>

    <!-- Champ Email -->
    <VBox spacing="5">
        <Label text="Email" style="-fx-font-weight: bold;"/>
        <TextField fx:id="emailField"
                   promptText="Entrez votre email"
                   style="-fx-pref-width: 300px; -fx-pref-height: 35px;"/>
    </VBox>

    <!-- Champ Mot de passe -->
    <VBox spacing="5">
        <Label text="Mot de passe" style="-fx-font-weight: bold;"/>
        <PasswordField fx:id="motDePasseField"
                       promptText="Entrez votre mot de passe"
                       style="-fx-pref-width: 300px; -fx-pref-height: 35px;"/>
    </VBox>

    <!-- Message d'erreur -->
    <Label fx:id="messageErreur"
           text=""
           style="-fx-text-fill: red; -fx-font-size: 12px;"/>

    <!-- Bouton de connexion -->
    <Button fx:id="btnConnexion"
            text="Se connecter"
            onAction="#handleConnexion"
            style="-fx-background-color: #2c3e50; -fx-text-fill: white;
                   -fx-pref-width: 300px; -fx-pref-height: 40px;
                   -fx-font-size: 14px; -fx-cursor: hand;"/>

</VBox>

