<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.asimov.controller.EleveController"
            style="-fx-background-color: #f4f4f4;">

    <!-- HEADER -->
    <top>
        <HBox style="-fx-background-color: #2c3e50; -fx-padding: 15;">
            <Label text="👨‍🎓 Gestion des Élèves"
                   style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <!-- TABLEAU -->
    <center>
        <VBox spacing="10" style="-fx-padding: 15;">

            <!-- Barre de recherche + bouton Actualiser -->
            <HBox spacing="10">
                <TextField fx:id="searchField" promptText="Rechercher un élève..."
                           style="-fx-pref-width: 300px;"/>
                <Button text="🔍 Rechercher" onAction="#rechercherEleve"
                        style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
                <Button text="↺ Actualiser" onAction="#chargerEleves"
                        style="-fx-background-color: #7f8c8d; -fx-text-fill: white;"/>
            </HBox>

            <!-- TableView -->
            <TableView fx:id="tableEleves" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: white;">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colNumero" text="N° Élève" prefWidth="120"/>
                    <TableColumn fx:id="colIdClasse" text="Classe" prefWidth="80"/>
                    <TableColumn fx:id="colDateInscription" text="Date Inscription" prefWidth="150"/>
                    <TableColumn fx:id="colAnneeScolaire" text="Année Scolaire" prefWidth="130"/>
                    <TableColumn fx:id="colActif" text="Actif" prefWidth="80"/>
                    <TableColumn fx:id="colRedoublant" text="Redoublant" prefWidth="100"/>
                </columns>
                <placeholder>
                    <Label text="Aucun élève trouvé"/>
                </placeholder>
            </TableView>

            <!-- Boutons CRUD -->
            <HBox spacing="10">
                <Button text="➕ Ajouter" onAction="#ouvrirFormAjout"
                        style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-pref-width: 120;"/>
                <Button text="✏️ Modifier" onAction="#ouvrirFormModifier"
                        style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-pref-width: 120;"/>
                <Button text="🗑️ Supprimer" onAction="#supprimerEleve"
                        style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-pref-width: 120;"/>
                <Label fx:id="labelStatus" style="-fx-text-fill: #27ae60; -fx-font-size: 13px;"/>
            </HBox>
        </VBox>
    </center>

    <!-- FORMULAIRE (droite) -->
    <right>
        <VBox fx:id="panneauForm" spacing="12" style="-fx-padding: 20; -fx-background-color: white;
              -fx-border-color: #ddd; -fx-pref-width: 280;" visible="false" managed="false">

            <Label fx:id="titreForm" text="Ajouter un élève"
                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

            <Label text="N° Élève"/>
            <TextField fx:id="fieldNumero" promptText="Ex: EL-2024-001"/>

            <Label text="ID Classe"/>
            <TextField fx:id="fieldIdClasse" promptText="Ex: 3"/>

            <Label text="Date Inscription"/>
            <TextField fx:id="fieldDateInscription" promptText="Ex: 2024-09-01"/>

            <Label text="Année Scolaire"/>
            <TextField fx:id="fieldAnneeScolaire" promptText="Ex: 2024-2025"/>

            <Label text="Statut"/>
            <ComboBox fx:id="comboActif" promptText="Actif ?"
                      style="-fx-pref-width: 240;"/>

            <CheckBox fx:id="checkRedoublant" text="Redoublant"/>

            <HBox spacing="10">
                <Button text="💾 Enregistrer" onAction="#enregistrerEleve"
                        style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-pref-width: 115;"/>
                <Button text="✖ Annuler" onAction="#annulerForm"
                        style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-pref-width: 115;"/>
            </HBox>
        </VBox>
    </right>

</BorderPane>